# Frontend (safe to expose — shipped in the browser bundle)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ---------------------------------------------------------------------------
# Server-side only (Netlify Functions). NEVER prefix with VITE_. Set these in
# Netlify: Site settings -> Environment variables.
# ---------------------------------------------------------------------------

# GeniusPay merchant API (https://geniuspay.ci -> Parametres -> API)
GENIUSPAY_BASE_URL=https://geniuspay.ci/api/v1/merchant
GENIUSPAY_API_KEY=pk_live_xxx
GENIUSPAY_API_SECRET=sk_live_xxx
# Returned once when you create the webhook in GeniusPay -> Webhooks:
GENIUSPAY_WEBHOOK_SECRET=whsec_xxx

# Supabase service role key (Supabase -> Project Settings -> API -> service_role)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
